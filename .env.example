# ── LLM 配置（必填）──
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# ── 数据库路径 ──
# DB_PATH=data/boss_hunter.db

# ── 日志级别: DEBUG / INFO / WARNING / ERROR ──
# LOG_LEVEL=INFO

# ── 匹配评分配置（可选，以下是默认值）──
# MATCH_CITY_SCORE=25
# MATCH_SALARY_SCORE=25
# MATCH_MUST_KEYWORD_SCORE=5
# MATCH_BONUS_KEYWORD_SCORE=3
# MATCH_WELFARE_SCORE=3
# MATCH_KEYWORD_CAP=15
# MATCH_WELFARE_CAP=10
# MATCH_RULE_LLM_THRESHOLD=50
# MATCH_RULE_WEIGHT=0.3
# MATCH_LLM_WEIGHT=0.7
# MATCH_PASS_THRESHOLD=55
# MATCH_HIGH_SCORE=70

# ── 打招呼配置（可选，以下是默认值）──
# DAILY_GREET_LIMIT=50
# GREET_INTERVAL_MIN=10
# GREET_INTERVAL_MAX=30
# GREET_BATCH_SIZE=10
# GREET_BATCH_REST=300

# ── LLM 超时 ──
# LLM_TIMEOUT=60
